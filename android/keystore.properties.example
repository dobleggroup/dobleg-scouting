# Copiá este archivo a "keystore.properties" (mismo directorio: android/) y completá
# con TUS datos. NO se versiona (está en .gitignore). Guardá el .jks y estas
# contraseñas en un lugar seguro: si los perdés, no podés volver a actualizar la app.
#
# Generar el keystore (una sola vez), desde android/:
#   keytool -genkey -v -keystore doble-g-scout.jks -keyalg RSA -keysize 2048 -validity 10000 -alias doble-g
#
storeFile=doble-g-scout.jks
storePassword=TU_PASSWORD_DEL_STORE
keyAlias=doble-g
keyPassword=TU_PASSWORD_DE_LA_CLAVE
